# Copy this file to .env for local development. Never commit the real .env.
# The browser only receives whether an LLM is configured; this key stays here.
LLM_API_KEY=

# OpenAI-compatible base URL. The server appends /chat/completions.
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Safety limits. MAX_REQUEST_BYTES accepts 1..1048576 bytes.
MAX_REQUEST_BYTES=65536
LLM_TIMEOUT_SECONDS=20
